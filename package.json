{
  "name": "face-fight",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export": "expo export --platform web && node -e \"const fs=require('fs');const p='dist/index.html';let h=fs.readFileSync(p,'utf8');h=h.replace('lang=\\\"en\\\"','lang=\\\"ja\\\"');fs.writeFileSync(p,h,'utf8');console.log('lang=ja applied');\""
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.33",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "expo": "~55.0.8",
    "expo-av": "^16.0.8",
    "expo-camera": "~55.0.10",
    "expo-constants": "^55.0.9",
    "expo-file-system": "~55.0.11",
    "expo-font": "^55.0.4",
    "expo-haptics": "^55.0.9",
    "expo-linking": "^55.0.8",
    "expo-router": "^55.0.7",
    "expo-sharing": "~55.0.14",
    "expo-splash-screen": "^55.0.12",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.2.3",
    "react-native-safe-area-context": "^5.7.0",
