{
  "expo": {
    "name": "顔バトル",
    "slug": "face-fight",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "facefight",
    "newArchEnabled": true,
    "description": "顔バトル - 自分の表情でバトル！怒り顔でパンチ、笑顔でバリア。顔認識AI搭載の顔バトルゲーム。キーワード: 顔ゲーム 表情ゲーム 顔認識 カメラゲーム バトルゲーム face game",
    "keywords": ["顔バトル", "表情ゲーム", "顔認識", "カメラゲーム", "FaceFight"],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "title": "顔バトル - 表情でたたかうリアルタイムRPG",
      "description": "カメラで自分の顔を認識。怒り・笑い・驚きの表情がスキルに変わる！無料で遊べる顔認識バトルゲーム",
      "themeColor": "#1a1a2e",
      "lang": "ja"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
